# ── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# ── Database (Prisma) ────────────────────────────────────────────────────────
# Reuses the existing MySQL neutroninvdb database.
# invoicing-backend/docker-compose.yml publishes MySQL on host port 3307.
DATABASE_URL="mysql://root:password@localhost:3307/neutroninvdb"

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me
JWT_EXPIRATION_MS=7200000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (SMTP via Nodemailer) ──────────────────────────────────────────────
# Generic SMTP settings (the ZEPTO_ prefix is historical — point them at any
# provider: a cPanel mailbox, ZeptoMail, Gmail, SendGrid, Mailgun, etc.).
# If HOST/USER/PASS are unset, emails are logged and skipped (dev-safe).
ZEPTO_HOST=smtp.zeptomail.com
ZEPTO_PORT=465          # 465 = SSL (secure). Use 587 for STARTTLS providers.
ZEPTO_USER=
ZEPTO_PASS=
ZEPTO_FROM=noreply@yourdomain.com   # must be an address your SMTP is allowed to send as
# ZEPTO_SECURE=          # optional: force true/false; defaults to (port === 465)

# ── Payments ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
